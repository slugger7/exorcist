{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "npm: dev",
      "isBackground": true,
      "command": "source ~/.zshrc && npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in"
        }
      }
    }
  ]
}
